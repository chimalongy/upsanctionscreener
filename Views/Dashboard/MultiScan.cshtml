@{
    ViewData["Title"] = "Multi-Scan";
    ViewData["ActivePage"] = "Search";
    ViewData["HideHeader"] = true;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { opacity: 0; animation: fadeUp 0.5s ease forwards; }
    .fade-up-1 { animation-delay: 0.05s; }
    .fade-up-2 { animation-delay: 0.15s; }
    .fade-up-3 { animation-delay: 0.25s; }

    @@keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 0.8s linear infinite; }

    .drop-active {
        border-color: var(--color-brand-400, #6366f1) !important;
        background-color: var(--color-brand-50, #eef2ff) !important;
    }

    .config-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-muted, #9ca3af);
        margin-bottom: 0.4rem;
        display: block;
    }
    .config-input {
        width: 100%;
        padding: 0.5rem 0.75rem;
        background: var(--color-surface-card, #ffffff);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 0.625rem;
        font-size: 0.8125rem;
        color: var(--color-text-primary, #111827);
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .config-input:focus {
        border-color: var(--color-brand-400, #6366f1);
        box-shadow: 0 0 0 2px var(--color-brand-100, #e0e7ff);
    }
    .config-input::placeholder { color: var(--color-text-muted, #9ca3af); }
    .config-input:disabled { opacity: 0.45; cursor: not-allowed; }

    .toggle-pill {
        display: flex; align-items: center; gap: 0.375rem;
        cursor: pointer; user-select: none;
    }
    .toggle-pill input[type="checkbox"] { display: none; }
    .pill-track {
        width: 2rem; height: 1.125rem;
        background: var(--color-border, #d1d5db);
        border-radius: 9999px; position: relative;
        transition: background 0.2s; flex-shrink: 0;
    }
    .pill-track::after {
        content: ''; position: absolute;
        top: 0.1875rem; left: 0.1875rem;
        width: 0.75rem; height: 0.75rem;
        background: #fff; border-radius: 50%;
        transition: transform 0.2s;
        box-shadow: 0 1px 2px rgba(0,0,0,0.15);
    }
    .toggle-pill input:checked + .pill-track { background: var(--color-brand-500, #6366f1); }
    .toggle-pill input:checked + .pill-track::after { transform: translateX(0.875rem); }

    .req-mark { color: #ef4444; margin-left: 2px; }
    .field-error { font-size: 0.7rem; color: #ef4444; margin-top: 0.25rem; display: none; }
    .field-error.visible { display: block; }

    .scan-type-badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.18rem 0.55rem;
        border-radius: 9999px;
        font-size: 0.68rem; font-weight: 600; letter-spacing: 0.03em;
    }
    .badge-document { background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; }
    .badge-list     { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }

    /* ── Ready card ── */
    #readyCard {
        background: linear-gradient(135deg, #f0fdf4 0%, #eff6ff 100%);
        border: 1px solid #bbf7d0;
    }
    #readyCard .big-check {
        width: 3rem; height: 3rem;
        background: #22c55e;
        border-radius: 9999px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .btn-start-screening {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.65rem 1.5rem;
        background: #22c55e; color: #fff;
        font-weight: 600; font-size: 0.875rem;
        border-radius: 0.75rem; border: none; cursor: pointer;
        transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
        box-shadow: 0 2px 8px rgba(34,197,94,0.35);
    }
    .btn-start-screening:hover {
        background: #16a34a;
        box-shadow: 0 4px 14px rgba(34,197,94,0.45);
        transform: translateY(-1px);
    }
    .btn-start-screening:active { transform: translateY(0); }
    .btn-start-screening svg { width: 1rem; height: 1rem; }

    /* ── Action buttons layout ── */
    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1.25rem;
    }

    .btn-submit {
        width: 100%;
        padding: 0.75rem 1.25rem;
        background: var(--color-accent-500, #6366f1);
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 0.75rem;
        border: none;
        cursor: pointer;
        transition: background 0.2s, opacity 0.15s;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 2.75rem;
    }
    .btn-submit:hover { background: var(--color-accent-600, #4f46e5); }
    .btn-submit:disabled { opacity: 0.65; cursor: not-allowed; }
    .btn-submit .btn-label  { transition: opacity 0.15s; display: flex; align-items: center; gap: 0.5rem; }
    .btn-submit .btn-spinner { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; gap: 0.5rem; }
    .btn-submit.loading .btn-label  { opacity: 0; }
    .btn-submit.loading .btn-spinner { display: flex; }

    .btn-secondary-action {
        width: 100%;
        padding: 0.7rem 1.25rem;
        background: var(--color-surface, #f9fafb);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 0.75rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text-secondary, #6b7280);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
        min-height: 2.75rem;
    }
    .btn-secondary-action:hover {
        border-color: var(--color-brand-300, #a5b4fc);
        color: var(--color-text-primary, #111827);
        background: var(--color-surface-card, #fff);
    }

    .btn-row-secondary {
        display: flex;
        gap: 0.75rem;
    }
    .btn-row-secondary .btn-secondary-action {
        flex: 1;
    }

    /* On larger screens, put submit + secondary row side by side */
    @@media (min-width: 540px) {
        .action-buttons {
            flex-direction: row;
            align-items: stretch;
        }
        .btn-submit {
            flex: 1;
            width: auto;
        }
        .btn-row-secondary {
            flex-direction: row;
        }
        .btn-row-secondary .btn-secondary-action {
            width: auto;
            flex: none;
            padding-left: 1.1rem;
            padding-right: 1.1rem;
        }
    }

    /* ══════════════════════════════════════════════════════════════
       SHARED MODAL BASE
    ══════════════════════════════════════════════════════════════ */
    .modal-overlay {
        position: fixed; inset: 0; z-index: 9999;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(3px);
        opacity: 0; pointer-events: none;
        transition: opacity 0.2s ease;
    }
    .modal-overlay.open {
        opacity: 1; pointer-events: auto;
    }
    .modal-box {
        background: var(--color-surface-card, #ffffff);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 1.25rem;
        padding: 1.75rem 2rem;
        max-width: 420px; width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.18);
        transform: translateY(12px) scale(0.97);
        transition: transform 0.2s ease;
    }
    .modal-overlay.open .modal-box {
        transform: translateY(0) scale(1);
    }
    .modal-icon-wrap {
        width: 3rem; height: 3rem;
        border-radius: 9999px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1rem;
    }
    .modal-icon-wrap.error   { background: #fef2f2; border: 1px solid #fecaca; }
    .modal-icon-wrap.warning { background: #fffbeb; border: 1px solid #fde68a; }

    .btn-modal-secondary {
        flex: 1; padding: 0.6rem 1rem;
        background: var(--color-surface, #f9fafb);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 0.75rem;
        font-size: 0.875rem; font-weight: 500;
        color: var(--color-text-secondary, #6b7280);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }
    .btn-modal-secondary:hover {
        border-color: var(--color-brand-300, #a5b4fc);
        color: var(--color-text-primary, #111827);
    }
    .btn-modal-danger {
        flex: 1; padding: 0.6rem 1rem;
        background: #ef4444; border: none;
        border-radius: 0.75rem;
        font-size: 0.875rem; font-weight: 600; color: #fff;
        cursor: pointer;
        transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
        box-shadow: 0 2px 8px rgba(239,68,68,0.3);
    }
    .btn-modal-danger:hover {
        background: #dc2626;
        box-shadow: 0 4px 14px rgba(239,68,68,0.4);
        transform: translateY(-1px);
    }
    .btn-modal-danger:active  { transform: translateY(0); }
    .btn-modal-danger:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-modal-danger .proc-spinner { display: none; }
    .btn-modal-danger.deleting .proc-label   { display: none; }
    .btn-modal-danger.deleting .proc-spinner {
        display: inline-flex; align-items: center; gap: 0.4rem;
    }

    .btn-modal-dismiss {
        width: 100%; padding: 0.6rem 1rem;
        background: var(--color-surface, #f9fafb);
        border: 1px solid var(--color-border, #e5e7eb);
        border-radius: 0.75rem;
        font-size: 0.875rem; font-weight: 500;
        color: var(--color-text-secondary, #6b7280);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }
    .btn-modal-dismiss:hover {
        border-color: var(--color-brand-300, #a5b4fc);
        color: var(--color-text-primary, #111827);
    }
    #errorModalDetail {
        font-size: 0.8rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 0.625rem;
        padding: 0.65rem 0.875rem;
        color: #b91c1c;
        margin-bottom: 1.25rem;
        word-break: break-word;
        line-height: 1.55;
        white-space: pre-wrap;
    }
</style>

@* ── Hero ── *@
<div class="text-center mb-8 pt-6 fade-up fade-up-1">
    <div class="w-16 h-16 bg-brand-50 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-brand-100">
        <svg class="w-8 h-8 text-brand-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/>
            <path d="M9 12h6M9 16h4"/>
        </svg>
    </div>
    <h1 class="font-display text-text-primary text-3xl font-semibold mb-2">Multi-Scan</h1>
    <p class="text-text-secondary text-sm max-w-md mx-auto">
        Upload a CSV or Excel file, or paste names to screen multiple entities against UP Sanctions lists at once.
    </p>
</div>

@* ── Input card ── *@
<div id="inputCard" class="bg-surface-card border border-border rounded-2xl px-6 py-6 shadow-sm mb-6 fade-up fade-up-2">

    @* ── Tabs ── *@
    <div class="flex items-center gap-1.5 mb-5 bg-surface rounded-xl p-1 border border-border">
        <button onclick="switchTab('upload')" id="tab-upload"
                class="tab-btn flex-1 py-2 text-xs font-medium rounded-lg transition-colors bg-brand-500 text-white">
            <span class="flex items-center justify-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
                Upload Document
            </span>
        </button>
        <button onclick="switchTab('paste')" id="tab-paste"
                class="tab-btn flex-1 py-2 text-xs font-medium rounded-lg transition-colors text-text-secondary hover:text-brand-700">
            <span class="flex items-center justify-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                </svg>
                Paste List
            </span>
        </button>
    </div>

    @* ════════════════════════════════════════════════════════════
       PANEL A — Document upload
    ════════════════════════════════════════════════════════════ *@
    <div id="panel-upload">

        <div id="dropZone"
             class="border-2 border-dashed border-border rounded-xl p-10 text-center cursor-pointer
                    transition-colors hover:border-brand-300 hover:bg-brand-50"
             onclick="document.getElementById('multiFile').click()"
             ondragover="onDragOver(event)"
             ondragleave="onDragLeave(event)"
             ondrop="onDrop(event)">
            <svg class="w-10 h-10 mx-auto mb-3 text-text-muted" fill="none" stroke="currentColor"
                 stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M4 16v1a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-1"/>
                <polyline points="16 12 12 16 8 12"/>
                <line x1="12" y1="3" x2="12" y2="16"/>
            </svg>
            <p class="text-text-primary text-sm font-medium mb-1">Drop your file here or click to browse</p>
            <p class="text-text-muted text-xs">
                Supported: <strong>.csv</strong> &middot; <strong>.xlsx</strong> &middot; <strong>.xls</strong>
            </p>
        </div>

        <input id="multiFile" type="file" accept=".csv,.xlsx,.xls"
               class="hidden" onchange="handleFileSelect(event)" />

        @* File info strip *@
        <div id="fileInfo"
             class="hidden mt-3 flex items-center gap-2 text-sm text-text-secondary
                    bg-surface border border-border rounded-xl px-4 py-2.5">
            <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor"
                 stroke-width="2" viewBox="0 0 24 24">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            <span id="fileName" class="truncate flex-1 text-xs font-mono"></span>
            <span class="scan-type-badge badge-document flex-shrink-0">
                <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z"/>
                </svg>
                document
            </span>
            <button onclick="clearFile()"
                    class="text-text-muted hover:text-error transition-colors flex-shrink-0 ml-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>

        @* ── Column mapping ── *@
        <div id="fileConfig" class="hidden mt-4">
            <div class="border-t border-border pt-4">
                <p class="text-xs font-semibold text-text-primary mb-3 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-brand-500" fill="none" stroke="currentColor"
                         stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                    </svg>
                    Column Mapping
                </p>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <div>
                        <label class="config-label" for="scanColumnInput">
                            Column to Scan <span class="req-mark">*</span>
                        </label>
                        <input id="scanColumnInput" type="text" class="config-input"
                               placeholder="e.g. Full Name, entity_name…" autocomplete="off" />
                        <p class="field-error" id="err-scanColumn">Please enter the column name to scan.</p>
                        <p class="text-[11px] text-text-muted mt-1">
                            Exact header name from your file. Values here are screened against sanctions lists.
                        </p>
                    </div>
                    <div>
                        <label class="config-label">
                            Record ID Column <span class="req-mark">*</span>
                        </label>
                        <div class="flex items-center gap-3 mb-2">
                            <label class="toggle-pill">
                                <input type="checkbox" id="autoIdCheck" onchange="toggleAutoId()" />
                                <span class="pill-track"></span>
                                <span class="text-xs text-text-secondary">Auto-generate IDs</span>
                            </label>
                        </div>
                        <div id="idColumnWrap">
                            <input id="idColumnInput" type="text" class="config-input"
                                   placeholder="e.g. ID, record_id, CustomerID…" autocomplete="off" />
                            <p class="field-error" id="err-idColumn">
                                Enter the ID column name or enable auto-generate.
                            </p>
                        </div>
                        <p class="text-[11px] text-text-muted mt-1">
                            Used to uniquely identify each record in the results.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <p class="text-[11px] text-text-muted mt-3">
            Need a template?
            <a href="#" onclick="downloadTemplate(); return false;"
               class="text-brand-500 hover:underline">Download sample CSV</a>
        </p>
    </div>

    @* ════════════════════════════════════════════════════════════
       PANEL B — Paste list
    ════════════════════════════════════════════════════════════ *@
    <div id="panel-paste" class="hidden">
        <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-medium text-text-secondary">Paste names — one per line</label>
            <span class="scan-type-badge badge-list">
                <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                          d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h8a1 1 0 110 2H4a1 1 0 01-1-1z"
                          clip-rule="evenodd"/>
                </svg>
                non-document
            </span>
        </div>
        <textarea id="pasteInput" rows="8"
                  placeholder="Paste names here, one per line&#10;e.g.&#10;Nikolai Volkov&#10;Ahmed Al-Rashid&#10;Eastern Bridge Corp"
                  class="w-full px-4 py-3 bg-surface border border-border rounded-xl text-text-primary
                         text-sm placeholder-text-muted resize-none
                         focus:outline-none focus:border-brand-400 focus:ring-2 focus:ring-brand-100
                         transition-colors font-mono"></textarea>
        <p id="pasteCount" class="text-[11px] text-text-muted mt-1">0 entries detected</p>
    </div>

    @* ── Actions ── *@
    <div class="action-buttons">

        @* Primary: Upload & Prepare *@
        <button id="submitBtn" onclick="runMultiScan()" class="btn-submit">
            <span class="btn-label">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                Upload &amp; Prepare Scan
            </span>
            <span class="btn-spinner">
                <svg class="w-4 h-4 spinner flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                </svg>
                Uploading…
            </span>
        </button>

        @* Secondary row: View All Scans + Back *@
        <div class="btn-row-secondary">
            <a href="@Url.Action("MultiScanTasks", "Dashboard")" class="btn-secondary-action">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                    <rect x="9" y="3" width="6" height="4" rx="1"/>
                    <path d="M9 12h6M9 16h4"/>
                </svg>
                View All Scans
            </a>
            <a href="@Url.Action("Index", "Dashboard")" class="btn-secondary-action">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back
            </a>
        </div>

    </div>

</div>

@* ── Ready card ── *@
<div id="readyCard" class="hidden rounded-2xl px-6 py-6 shadow-sm mb-6 fade-up">
    <div class="flex items-start gap-4">
        <div class="big-check">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path d="M20 6 9 17l-5-5"/>
            </svg>
        </div>
        <div class="flex-1 min-w-0">
            <p class="text-text-primary font-semibold text-base mb-0.5">Ready to Screen</p>
            <p class="text-text-secondary text-sm mb-3" id="readySummary"></p>
            <div class="flex flex-wrap gap-3 text-xs text-text-secondary mb-4">
                <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    <span id="readyFileName" class="font-mono truncate max-w-[220px]"></span>
                </span>
                <span id="readyScanTypeBadge" class="scan-type-badge badge-document"></span>
            </div>
            <div class="flex flex-wrap gap-3">
                <button onclick="startScreening()" class="btn-start-screening">
                    <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                    Start Screening
                </button>
                <button onclick="promptChangeFile()"
                        class="px-4 py-2 bg-surface border border-border hover:border-brand-300
                               text-text-secondary text-sm rounded-xl transition-colors">
                    Change File / List
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Error Modal ── *@
<div id="errorModal" class="modal-overlay" role="alertdialog" aria-modal="true" aria-labelledby="errorModalTitle">
    <div class="modal-box">
        <div class="modal-icon-wrap error">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4M12 16h.01"/>
            </svg>
        </div>
        <h2 id="errorModalTitle" class="text-text-primary font-semibold text-base mb-1.5"></h2>
        <div id="errorModalDetail"></div>
        <button class="btn-modal-dismiss" onclick="closeErrorModal()">Dismiss</button>
    </div>
</div>

@* ── Delete-Confirm Modal ── *@
<div id="deleteModal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
    <div class="modal-box">
        <div class="modal-icon-wrap warning">
            <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                <path d="M10 11v6M14 11v6"/>
            </svg>
        </div>
        <h2 id="deleteModalTitle" class="text-text-primary font-semibold text-base mb-1">Discard this upload?</h2>
        <p class="text-text-secondary text-sm mb-5">
            The file currently saved on the server will be <strong>permanently deleted</strong>.
            You will need to re-upload or re-paste your data before running another scan.
        </p>
        <div class="flex gap-3">
            <button class="btn-modal-secondary" onclick="closeDeleteModal()">Cancel</button>
            <button id="proceedDeleteBtn" class="btn-modal-danger" onclick="proceedDelete()">
                <span class="proc-label flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                    </svg>
                    Yes, Delete &amp; Reset
                </span>
                <span class="proc-spinner">
                    <svg class="w-3.5 h-3.5 spinner" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                    </svg>
                    Deleting…
                </span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ═══════════════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════════════ */
let activeTab    = 'upload';
let loadedFile   = null;
let uploadResult = null;

/* ═══════════════════════════════════════════════════════════════════
   ANTIFORGERY TOKEN
═══════════════════════════════════════════════════════════════════ */
function getToken() {
    const el = document.querySelector('input[name="__RequestVerificationToken"]');
    return el ? el.value : '';
}

/* ═══════════════════════════════════════════════════════════════════
   ERROR MODAL
═══════════════════════════════════════════════════════════════════ */
function showError(title, message) {
    document.getElementById('errorModalTitle').textContent  = title;
    document.getElementById('errorModalDetail').textContent = message;
    document.getElementById('errorModal').classList.add('open');
}
function closeErrorModal() {
    document.getElementById('errorModal').classList.remove('open');
}
document.getElementById('errorModal').addEventListener('click', function (e) {
    if (e.target === this) closeErrorModal();
});

/* ═══════════════════════════════════════════════════════════════════
   GLOBAL ESCAPE KEY
═══════════════════════════════════════════════════════════════════ */
document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { closeErrorModal(); closeDeleteModal(); }
});

/* ═══════════════════════════════════════════════════════════════════
   TAB SWITCHING
═══════════════════════════════════════════════════════════════════ */
function switchTab(tab) {
    activeTab = tab;
    ['upload', 'paste'].forEach(t => {
        const isActive = t === tab;
        document.getElementById('tab-'   + t).classList.toggle('bg-brand-500',       isActive);
        document.getElementById('tab-'   + t).classList.toggle('text-white',          isActive);
        document.getElementById('tab-'   + t).classList.toggle('text-text-secondary', !isActive);
        document.getElementById('panel-' + t).classList.toggle('hidden',              !isActive);
    });
}

/* ═══════════════════════════════════════════════════════════════════
   PASTE COUNTER
═══════════════════════════════════════════════════════════════════ */
document.getElementById('pasteInput').addEventListener('input', function () {
    const n = this.value.split('\n').map(l => l.trim()).filter(Boolean).length;
    document.getElementById('pasteCount').textContent =
        `${n} entr${n === 1 ? 'y' : 'ies'} detected`;
});

/* ═══════════════════════════════════════════════════════════════════
   DRAG & DROP / FILE SELECT
═══════════════════════════════════════════════════════════════════ */
function onDragOver(e) {
    e.preventDefault();
    document.getElementById('dropZone').classList.add('drop-active');
}
function onDragLeave() {
    document.getElementById('dropZone').classList.remove('drop-active');
}
function onDrop(e) {
    e.preventDefault();
    document.getElementById('dropZone').classList.remove('drop-active');
    const f = e.dataTransfer.files[0];
    if (f) attachFile(f);
}
function handleFileSelect(e) {
    const f = e.target.files[0];
    if (f) attachFile(f);
}
function attachFile(file) {
    const ext = file.name.split('.').pop().toLowerCase();
    if (!['csv', 'xlsx', 'xls'].includes(ext)) {
        showError(
            'Unsupported File Type',
            'Please upload a .csv, .xlsx, or .xls file.\n\nYou selected: ' + file.name
        );
        return;
    }
    loadedFile = file;
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileInfo').classList.remove('hidden');
    document.getElementById('fileConfig').classList.remove('hidden');
}
function clearFile() {
    loadedFile = null;
    document.getElementById('multiFile').value        = '';
    document.getElementById('fileInfo').classList.add('hidden');
    document.getElementById('fileConfig').classList.add('hidden');
    document.getElementById('scanColumnInput').value  = '';
    document.getElementById('idColumnInput').value    = '';
    document.getElementById('autoIdCheck').checked    = false;
    document.getElementById('idColumnInput').disabled = false;
    document.getElementById('idColumnWrap').style.opacity = '1';
    hideFieldError('err-scanColumn');
    hideFieldError('err-idColumn');
}

/* ═══════════════════════════════════════════════════════════════════
   AUTO-ID TOGGLE
═══════════════════════════════════════════════════════════════════ */
function toggleAutoId() {
    const on = document.getElementById('autoIdCheck').checked;
    document.getElementById('idColumnInput').disabled     = on;
    document.getElementById('idColumnWrap').style.opacity = on ? '0.4' : '1';
    if (on) hideFieldError('err-idColumn');
}

/* ═══════════════════════════════════════════════════════════════════
   VALIDATION
═══════════════════════════════════════════════════════════════════ */
function showFieldError(id) { document.getElementById(id).classList.add('visible'); }
function hideFieldError(id) { document.getElementById(id).classList.remove('visible'); }

function validateDocumentConfig() {
    let ok = true;
    if (!document.getElementById('scanColumnInput').value.trim()) {
        showFieldError('err-scanColumn'); ok = false;
    } else { hideFieldError('err-scanColumn'); }

    const autoId = document.getElementById('autoIdCheck').checked;
    if (!autoId && !document.getElementById('idColumnInput').value.trim()) {
        showFieldError('err-idColumn'); ok = false;
    } else { hideFieldError('err-idColumn'); }

    return ok;
}

/* ═══════════════════════════════════════════════════════════════════
   TEMPLATE DOWNLOAD
═══════════════════════════════════════════════════════════════════ */
function downloadTemplate() {
    const csv  = 'ID,Name\n1,Nikolai Volkov\n2,Ahmed Al-Rashid\n3,Eastern Bridge Corp';
    const blob = new Blob([csv], { type: 'text/csv' });
    const a    = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'multiscan_template.csv';
    a.click();
}

/* ═══════════════════════════════════════════════════════════════════
   ENTRY POINT
═══════════════════════════════════════════════════════════════════ */
async function runMultiScan() {
    if (activeTab === 'upload') {
        if (!loadedFile) {
            showError('No File Selected',
                'Please upload a .csv, .xlsx, or .xls file before continuing.');
            return;
        }
        if (!validateDocumentConfig()) { return; }
        await submitDocument();
    } else {
        const names = document.getElementById('pasteInput').value
            .split('\n').map(l => l.trim()).filter(Boolean);
        if (!names.length) {
            showError('No Names Entered',
                'Please paste at least one name into the text area before continuing.');
            return;
        }
        await submitPasteList(names);
    }
}

/* ═══════════════════════════════════════════════════════════════════
   PATH A — non-document
═══════════════════════════════════════════════════════════════════ */
async function submitPasteList(names) {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true; btn.classList.add('loading');

    try {
        const response = await fetch('/Dashboard/MultiScan/Upload/Paste', {
            method : 'POST',
            headers: {
                'Content-Type'            : 'application/json',
                'X-Requested-With'        : 'XMLHttpRequest',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ scanType: 'non-document', nameList: names.join('\n') })
        });
        await handleResponse(response, 'non-document');
    } catch (ex) {
        console.error('submitPasteList error:', ex);
        showError('Network Error',
            'Could not reach the server. Please check your connection and try again.\n\n' + ex.message);
    } finally {
        btn.disabled = false; btn.classList.remove('loading');
    }
}

/* ═══════════════════════════════════════════════════════════════════
   PATH B — document
═══════════════════════════════════════════════════════════════════ */
async function submitDocument() {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true; btn.classList.add('loading');

    try {
        const formData = new FormData();
        formData.append('scanType',       'document');
        formData.append('file',           loadedFile);
        formData.append('scanColumn',     document.getElementById('scanColumnInput').value.trim());
        formData.append('autoGenerateId', document.getElementById('autoIdCheck').checked ? 'true' : 'false');
        if (!document.getElementById('autoIdCheck').checked) {
            formData.append('idColumn', document.getElementById('idColumnInput').value.trim());
        }

        const response = await fetch('/Dashboard/MultiScan/Upload/Document', {
            method : 'POST',
            headers: {
                'X-Requested-With'        : 'XMLHttpRequest',
                'RequestVerificationToken': getToken()
            },
            body: formData
        });
        await handleResponse(response, 'document');
    } catch (ex) {
        console.error('submitDocument error:', ex);
        showError('Network Error',
            'Could not reach the server. Please check your connection and try again.\n\n' + ex.message);
    } finally {
        btn.disabled = false; btn.classList.remove('loading');
    }
}

/* ═══════════════════════════════════════════════════════════════════
   RESPONSE HANDLER
═══════════════════════════════════════════════════════════════════ */
async function handleResponse(response, scanType) {
    let data;
    const rawText = await response.text();
    try {
        data = JSON.parse(rawText);
    } catch (_) {
        console.error('Non-JSON response:\n', rawText);
        showError('Unexpected Server Response',
            'The server returned a response that could not be understood. Check the browser console for the raw output.');
        return;
    }

    if (!response.ok || !data.success) {
        showError('Upload Failed',
            data.message || `The server responded with HTTP ${response.status}.`);
        return;
    }

    uploadResult = data;
    showReadyCard(data, scanType);
}

/* ═══════════════════════════════════════════════════════════════════
   READY CARD
═══════════════════════════════════════════════════════════════════ */
function showReadyCard(data, scanType) {
    document.getElementById('inputCard').classList.add('hidden');
    document.getElementById('readyCard').classList.remove('hidden');

    const count = data.rowCount ?? 0;
    document.getElementById('readySummary').textContent =
        `${count} ${count === 1 ? 'record' : 'records'} loaded and saved — ready to run sanctions screening.`;
    document.getElementById('readyFileName').textContent = data.fileName || '—';

    const badge = document.getElementById('readyScanTypeBadge');
    if (scanType === 'document') {
        badge.textContent = 'document';
        badge.className   = 'scan-type-badge badge-document';
    } else {
        badge.textContent = 'non-document';
        badge.className   = 'scan-type-badge badge-list';
    }
}

/* ═══════════════════════════════════════════════════════════════════
   START SCREENING
═══════════════════════════════════════════════════════════════════ */
function startScreening() {
    if (!uploadResult) return;

    const params = new URLSearchParams({
        filePath      : uploadResult.savedFilePath,
        fileName      : uploadResult.fileName      ?? '',
        rowCount      : uploadResult.rowCount       ?? 0,
        scanType      : uploadResult.scanType       ?? (activeTab === 'upload' ? 'document' : 'non-document'),
        scanColumn    : uploadResult.scanColumn     ?? document.getElementById('scanColumnInput').value.trim(),
        idColumn      : uploadResult.idColumn       ?? document.getElementById('idColumnInput').value.trim(),
        autoGenerateId: uploadResult.autoGenerateId ?? document.getElementById('autoIdCheck').checked
    });

    window.location.href = '/Dashboard/MultiScan/Screen?' + params.toString();
}

/* ═══════════════════════════════════════════════════════════════════
   DELETE MODAL
═══════════════════════════════════════════════════════════════════ */
function promptChangeFile() {
    document.getElementById('deleteModal').classList.add('open');
}
function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('open');
}
document.getElementById('deleteModal').addEventListener('click', function (e) {
    if (e.target === this) closeDeleteModal();
});

async function proceedDelete() {
    if (!uploadResult || !uploadResult.savedFilePath) {
        closeDeleteModal();
        hardReset();
        return;
    }

    const btn = document.getElementById('proceedDeleteBtn');
    btn.disabled = true; btn.classList.add('deleting');

    try {
        const response = await fetch('/Dashboard/MultiScan/DeleteUpload', {
            method : 'POST',
            headers: {
                'Content-Type'            : 'application/json',
                'X-Requested-With'        : 'XMLHttpRequest',
                'RequestVerificationToken': getToken()
            },
            body: JSON.stringify({ filePath: uploadResult.savedFilePath })
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.success) {
            closeDeleteModal();
            showError('Delete Failed',
                data.message || `The server responded with HTTP ${response.status}.`);
            return;
        }

        closeDeleteModal();
        hardReset();

    } catch (ex) {
        console.error('proceedDelete error:', ex);
        closeDeleteModal();
        showError('Network Error',
            'Could not reach the server while deleting the file.\n\n' + ex.message);
    } finally {
        btn.disabled = false; btn.classList.remove('deleting');
    }
}

/* ═══════════════════════════════════════════════════════════════════
   HARD RESET
═══════════════════════════════════════════════════════════════════ */
function hardReset() {
    uploadResult = null;
    document.getElementById('readyCard').classList.add('hidden');
    document.getElementById('inputCard').classList.remove('hidden');
    clearFile();
    document.getElementById('pasteInput').value = '';
    document.getElementById('pasteCount').textContent = '0 entries detected';
}
</script>
}