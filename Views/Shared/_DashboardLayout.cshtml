<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UP Sanction Scan Portal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Waffle menu ── */
        #waffleDropdown {
            transform-origin: top right;
            transform: scale(0.92) translateY(-8px);
            opacity: 0;
            pointer-events: none;
            transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                        opacity 0.15s ease;
        }
        #waffleDropdown.open {
            transform: scale(1) translateY(0);
            opacity: 1;
            pointer-events: auto;
        }
        .nav-tile {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 12px 8px;
            border-radius: 12px;
            cursor: pointer;
            transition: background 0.15s ease;
            text-decoration: none;
        }
        .nav-tile:hover { background: var(--color-brand-50, #eff6ff); }
        .nav-tile.active { background: var(--color-brand-50, #eff6ff); }
        .nav-tile.active span { color: var(--color-brand-500, #3b82f6); font-weight: 600; }
        .nav-tile.active svg  { color: var(--color-brand-500, #3b82f6); }
        .nav-tile.watchlist:hover  { background: var(--color-accent-50, #fdf4ff); }
        .nav-tile.watchlist.active { background: var(--color-accent-50, #fdf4ff); }
        .nav-tile.watchlist.active span,
        .nav-tile.watchlist.active svg { color: var(--color-accent-500, #a855f7); }
    </style>
</head>
<body class="bg-surface min-h-screen font-body pb-10">

  @{
    var hideHeader = (bool)(ViewData["HideHeader"] ?? false);
}

    @* ── Full header — hidden on Dashboard/Index ── *@
    @if (!hideHeader)
    {
        <header class="bg-surface-card border-b border-border px-6 py-3 flex items-center justify-between shadow-sm sticky top-0 z-40">
            <div class="flex items-center gap-1">
                <div class="w-7 h-7 rounded-md overflow-hidden">
                    <img src="~/images/logo.png" alt="Logo" class="w-full h-full object-contain" />
                </div>
                <span class="text-text-primary text-sm font-semibold tracking-wide">Sanction Screen</span>
            </div>
            <div class="flex items-center gap-3">
                @{
    var fullName   = User.FindFirst("firstName")?.Value + " " + User.FindFirst("lastName")?.Value;
    var userEmail  = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
    var userRole   = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var department = User.FindFirst("department")?.Value;
}
                @await Html.PartialAsync("_WaffleMenu")
            </div>
        </header>
    }

    @* ── Waffle floats top-right on Dashboard/Index (no header) ── *@
    @if (hideHeader)
    {
        <div class="fixed top-4 right-4 z-50">
            @await Html.PartialAsync("_WaffleMenu")
        </div>
    }

    @* ── Page content ── *@
    <main class="max-w-5xl mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <script>
        //<![CDATA[
        function toggleWaffle() {
            const btn      = document.getElementById('waffleBtn');
            const dropdown = document.getElementById('waffleDropdown');
            const isOpen   = dropdown.classList.contains('open');
            dropdown.classList.toggle('open', !isOpen);
            btn.classList.toggle('open', !isOpen);
        }

        document.addEventListener('click', function (e) {
            const btn      = document.getElementById('waffleBtn');
            const dropdown = document.getElementById('waffleDropdown');
            if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.remove('open');
                btn.classList.remove('open');
            }
        });
        //]]>
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>