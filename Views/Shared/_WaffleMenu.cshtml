@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var isAdmin = userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="relative">
    <button id="waffleBtn" onclick="toggleWaffle()"
            class="w-9 h-9 flex items-center justify-center rounded-xl
        hover:bg-brand-50 border border-transparent hover:border-border
        bg-surface-card shadow-sm transition-colors focus:outline-none">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor"
             class="text-text-muted">
            <circle cx="2" cy="2" r="1.6" />
            <circle cx="9" cy="2" r="1.6" />
            <circle cx="16" cy="2" r="1.6" />
            <circle cx="2" cy="9" r="1.6" />
            <circle cx="9" cy="9" r="1.6" />
            <circle cx="16" cy="9" r="1.6" />
            <circle cx="2" cy="16" r="1.6" />
            <circle cx="9" cy="16" r="1.6" />
            <circle cx="16" cy="16" r="1.6" />
        </svg>
    </button>

    <div id="waffleDropdown"
         class="absolute right-0 top-12 w-72
        bg-surface-card border border-border rounded-2xl shadow-xl
        p-4 z-50">

        @* ── Search ── *@
        <p class="text-[10px] text-text-muted font-medium uppercase tracking-widest px-1 mb-2">Search</p>
        <div class="grid grid-cols-3 gap-1 mb-4">
            <a href="/Dashboard/Index"
                   class="nav-tile @(ViewData["ActivePage"]?.ToString() == "Search" ? "active" : "")">
                <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                <span class="text-[10px] text-text-muted">Search</span>
            </a>
        </div>

        <div class="border-t border-border mb-3"></div>

        @* ── Lists ── *@
        <p class="text-[10px] text-text-muted font-medium uppercase tracking-widest px-1 mb-2">Lists</p>
        <div class="grid grid-cols-3 gap-1 mb-4">

            <a href="/Dashboard/List/UBOs"
                   class="nav-tile @(ViewData["ActivePage"]?.ToString() == "UBOs" ? "active" : "")">
                <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
                <span class="text-[10px] text-text-muted">UBOs</span>
            </a>

            <a href="/Dashboard/List/PEPs"
                   class="nav-tile @(ViewData["ActivePage"]?.ToString() == "PEPs" ? "active" : "")">
                <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                </svg>
                <span class="text-[10px] text-text-muted">PEPs</span>
            </a>

            <a href="/Dashboard/List/NigerianSanctionList"
                   class="nav-tile @(ViewData["ActivePage"]?.ToString() == "NigerianSanctionList" ? "active" : "")">
                <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
                <span class="text-[10px] text-text-muted">NG Sanctions</span>
            </a>

        </div>

        <div class="border-t border-border mb-3"></div>

        @* ── Reports ── *@
        <p class="text-[10px] text-text-muted font-medium uppercase tracking-widest px-1 mb-2">Reports</p>
        <div class="grid grid-cols-3 gap-1 mb-4">
            <a href="/Dashboard/Reports/TargetScanReports"
                   class="nav-tile @(ViewData["ActivePage"]?.ToString() == "TargetScanReports" ? "active" : "")">
                <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <circle cx="12" cy="12" r="6" />
                    <circle cx="12" cy="12" r="2" />
                </svg>
                <span class="text-[10px] text-text-muted">Target Scans</span>
            </a>
        </div>

        @* ── Settings (Admin only) ── *@
        @if (isAdmin)
        {
            <div class="border-t border-border mb-3"></div>

            <p class="text-[10px] text-text-muted font-medium uppercase tracking-widest px-1 mb-2">Settings</p>
            <div class="grid grid-cols-3 gap-1 mb-4">

                <a href="/Dashboard/Settings/ScanSettings"
                       class="nav-tile @(ViewData["ActivePage"]?.ToString() == "ScanSettings" ? "active" : "")">
                    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06
                        a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09
                        A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83
                        l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09
                        A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83
                        l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09
                        a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83
                        l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09
                        a1.65 1.65 0 0 0-1.51 1z" />
                    </svg>
                    <span class="text-[10px] text-text-muted">Scan</span>
                </a>

                <a href="/Dashboard/Settings/Users"
                       class="nav-tile @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")">
                    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                    <span class="text-[10px] text-text-muted">Users</span>
                </a>

                <a href="/Dashboard/Settings/TargetSettings"
                       class="nav-tile @(ViewData["ActivePage"]?.ToString() == "TargetSettings" ? "active" : "")">
                    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" />
                        <circle cx="12" cy="12" r="6" />
                        <circle cx="12" cy="12" r="2" />
                    </svg>
                    <span class="text-[10px] text-text-muted">Targets</span>
                </a>

                <a href="/Dashboard/Settings/SourceSettings"
                       class="nav-tile @(ViewData["ActivePage"]?.ToString() == "SourceSettings" ? "active" : "")">
                    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <ellipse cx="12" cy="5" rx="9" ry="3" />
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                    </svg>
                    <span class="text-[10px] text-text-muted">Sources</span>
                </a>

                <a href="/Dashboard/Settings/AuditLogs"
                       class="nav-tile @(ViewData["ActivePage"]?.ToString() == "AuditLogs" ? "active" : "")">
                    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="8" y1="13" x2="16" y2="13" />
                        <line x1="8" y1="17" x2="12" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                    <span class="text-[10px] text-text-muted">Audit Logs</span>
                </a>

            </div>
        }

        @* ── Sign out ── *@
        <div class="border-t border-border pt-3">
            <a asp-controller="Auth" asp-action="Logout"
                   class="nav-tile w-full flex-row justify-start gap-3 px-3 py-2
                text-accent-600 hover:bg-accent-50 rounded-xl">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor"
                     stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                <span class="text-xs font-medium">Sign out</span>
            </a>
        </div>

    </div>
</div>